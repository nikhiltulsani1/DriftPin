# Copy to .env and fill in for local development / CI.
# Never commit the populated .env file.

# Overrides the encrypted credential store; used primarily in CI.
ANTHROPIC_API_KEY=

# Base URL for a local Ollama instance. Only needed if it differs from the default.
OLLAMA_BASE_URL=http://localhost:11434

# Set in Release 3 when the OpenAI provider is added.
OPENAI_API_KEY=
